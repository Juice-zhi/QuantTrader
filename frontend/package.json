{
  "name": "quanttrader",
  "productName": "QuantTrader",
  "private": true,
  "version": "0.1.0",
  "description": "Quantitative Trading System - Factor Library + Strategy Engine + Backtest + Live Trading",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:3000 && NODE_ENV=development electron .\"",
    "electron:build": "tsc -b && vite build && electron-builder",
    "electron:preview": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.quanttrader.app",
    "productName": "QuantTrader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc",
          "!.pytest_cache/**",
          "!tests/**",
          "!data/**"
        ]
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "public/favicon.svg",
      "category": "public.app-category.finance"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "public/favicon.svg"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/favicon.svg",
      "category": "Finance"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
